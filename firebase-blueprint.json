{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Product category and level hierarchy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "parent_id": { "type": "string" },
        "display_order": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Product": {
      "title": "Product",
      "description": "Ecommerce product entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "category_id": { "type": "string" },
        "subcategory_id": { "type": "string" },
        "brand": { "type": "string" },
        "description": { "type": "string" },
        "long_description": { "type": "string" },
        "mrp": { "type": "number" },
        "sale_price": { "type": "number" },
        "dealer_price": { "type": "number" },
        "stock": { "type": "number" },
        "reserved": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "specs": { "type": "array", "items": { "$ref": "#/entities/Specification" } },
        "featured": { "type": "boolean" },
        "is360Supported": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "draft", "out_of_stock"] }
      },
      "required": ["name", "slug", "sku", "category_id", "mrp", "sale_price"]
    },
    "Specification": {
      "title": "Specification",
      "description": "Technical specs for a product.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Customer review on a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "userId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/OrderItem" } },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "couponCode": { "type": "string" },
        "shippingFee": { "type": "number" },
        "tax": { "type": "number" },
        "grandTotal": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["paid", "unpaid", "refunded"] },
        "trackingNumber": { "type": "string" }
      }
    },
    "OrderItem": {
      "title": "OrderItem",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "mrp": { "type": "number" }
      }
    },
    "QuoteRequest": {
      "title": "QuoteRequest",
      "description": "3D Print service request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quoteNumber": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerEmail": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "materialType": { "type": "string" },
        "color": { "type": "string" },
        "infill": { "type": "number" },
        "layerHeight": { "type": "number" },
        "weightGrams": { "type": "number" },
        "volumeCm3": { "type": "number" },
        "estimatedPrintTimeHours": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "estimated", "approved_by_customer", "rejected", "completed"] },
        "estimatedCost": { "type": "number" },
        "adjustmentFee": { "type": "number" },
        "mrpPrice": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Advertisement": {
      "title": "Advertisement",
      "description": "Banner campaigns.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "position": { "type": "string", "enum": ["top-banner", "sidebar", "footer", "sticky"] },
        "impressions": { "type": "number" },
        "clicks": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "paused"] },
        "revenuePerClick": { "type": "number" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountPercent": { "type": "number" },
        "minSpent": { "type": "number" },
        "active": { "type": "boolean" }
      }
    },
    "User": {
      "title": "User",
      "description": "Customer or Staff account.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "manager", "admin", "super-admin"] },
        "rewardPoints": { "type": "number" },
        "shippingAddress": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Store-wide configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "borderRadius": { "type": "number" },
        "fontFamily": { "type": "string" },
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "companyName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/quotes/{quoteId}": {
      "schema": "QuoteRequest",
      "description": "3D Print service quotes."
    },
    "/advertisements/{adId}": {
      "schema": "Advertisement",
      "description": "Marketing banners."
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog content."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount codes."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and metadata."
    },
    "/settings/global": {
      "schema": "Settings",
      "description": "Global store settings."
    }
  }
}
