{
  "name": "applet",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run setup-backend && ./dev-run.sh",
    "setup-backend": "cd server && npm install && npx prisma generate && npx prisma db push --accept-data-loss",
    "start": "concurrently \"node dist/applet/server/server.mjs\" \"cd server && BACKEND_PORT=4000 npx ts-node --transpile-only src/server.ts\"",
    "test-backend": "cd server && BACKEND_PORT=4000 npx ts-node --transpile-only src/server.ts",
    "build:server": "npx -y esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/applet/server/server.mjs --external:express --external:axios --external:firebase/* --external:firebase-admin",
    "build": "ng build && npm run build:server",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/material": "^19.0.2",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-server": "^19.2.25",
    "@angular/router": "^19.0.0",
    "@angular/ssr": "^19.0.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/compression": "^1.8.1",
    "@types/node-cache": "^4.1.3",
    "axios": "^1.17.0",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "express": "^4.21.1",
    "firebase": "^12.14.0",
    "http-proxy-middleware": "^4.1.0",
    "motion": "^12.40.0",
    "node-cache": "^5.1.2",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "razorpay": "^2.9.6",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@angular/build": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@types/busboy": "^1.5.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "5.6.3"
  }
}
