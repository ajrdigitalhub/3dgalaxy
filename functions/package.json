{
  "name": "functions",
  "version": "1.0.0",
  "description": "Customizable B2B 3D Fabricator Storefront Backend",
"scripts": {
  "dev": "npx prisma generate && ts-node-dev --respawn --transpile-only src/server.ts",
"build": "npx prisma generate && npx esbuild src/app.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/server.js --external:express --external:axios --external:firebase-admin --external:@prisma/client",
    "gcp-build": "npx prisma generate",
      "serve": "npm run build && firebase emulators:start --only functions",
  "shell": "npm run build && firebase functions:shell",
  "start": "npm run shell",
  "deploy": "firebase deploy --only functions",
  "logs": "firebase functions:log",
  "prisma:generate": "prisma generate",
  "prisma:migrate": "prisma migrate dev",
  "prisma:seed": "ts-node prisma/seed.ts"
},
    "engines": {
    "node": "24"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "@prisma/client": "^5.10.0",
    "@types/busboy": "^1.5.4",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.0",
     "prisma": "^5.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/pg": "^8.11.2",
    "@types/swagger-ui-express": "^4.1.6",
   
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
    
  },
  "private": true
}
