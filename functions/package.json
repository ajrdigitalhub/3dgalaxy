{
  "name": "functions",
  "version": "1.0.0",
  "description": "Customizable B2B 3D Fabricator Storefront Backend",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npx esbuild src/app.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/server.js --external:express --external:axios --external:firebase-admin --external:@prisma/client",
    "gcp-build": "npx prisma generate",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": "24"
  },
  "main": "index.js",
  "dependencies": {
    "@prisma/adapter-pg": "5.22.0",
    "@prisma/client": "5.22.0",
    "@types/busboy": "^1.5.4",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "prisma": "5.22.0",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/node-cache": "^4.1.3",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.2",
    "@types/swagger-ui-express": "^4.1.6",
    "firebase-functions-test": "^3.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
