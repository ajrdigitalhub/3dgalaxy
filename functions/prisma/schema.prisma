generator clientRoot {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

generator clientServer {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")
  users       UserRole[]

  @@map("roles")
}

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  passwordHash   String               @map("password_hash")
  firstName      String?              @map("first_name")
  lastName       String?              @map("last_name")
  mobile         String?
  profileImage   String?              @map("profile_image")
  dateOfBirth    DateTime?            @map("date_of_birth")
  gender         String?
  lastLogin      DateTime?            @map("last_login")
  isActive       Boolean              @default(true) @map("is_active")
  isVerified     Boolean              @default(false) @map("is_verified")
  deletedAt      DateTime?            @map("deleted_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at")
  auditLogs      AuditLog[]
  blogs          Blog[]
  customers      Customer[]
  notifications  Notification[]
  orderHistories OrderStatusHistory[]
  productReviews ProductReview[]
  refreshTokens  RefreshToken[]
  roles          UserRole[]

  @@map("users")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  expiresAt  DateTime @map("expires_at")
  revoked    Boolean  @default(false)
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldData    String?  @map("old_data")
  newData    String?  @map("new_data")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Category {
  id             String                @id @default(uuid())
  parentId       String?               @map("parent_id")
  name           String
  slug           String                @unique
  description    String?
  icon           String?
  image          String?
  banner         String?
  sortOrder      Int                   @default(0) @map("sort_order")
  isActive       Boolean               @default(true) @map("is_active")
  isFeatured     Boolean               @default(false) @map("is_featured")
  seoTitle       String?               @map("seo_title")
  seoDescription String?               @map("seo_description")
  deletedAt      DateTime?             @map("deleted_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @default(now()) @updatedAt @map("updated_at")
  parent         Category?             @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[]            @relation("CategoryHierarchy")
  homepageItems  HomepageSectionItem[]
  products       Product[]

  @@index([name])
  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  logo        String?   @map("logo_url")
  banner      String?   @map("banner_url")
  description String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  products    Product[]

  @@index([name])
  @@map("brands")
}

model Product {
  id              String                  @id @default(uuid())
  brandId         String?                 @map("brand_id")
  categoryId      String?                 @map("category_id")
  name            String
  slug            String                  @unique
  sku             String                  @unique
  description     String?
  basePrice       Float                   @map("base_price")
  salePrice       Float?                  @map("sale_price")
  dealerPrice     Float?                  @map("dealer_price")
  isActive        Boolean                 @default(true) @map("is_active")
  isExclusive     Boolean                 @default(false) @map("is_exclusive")
  deletedAt       DateTime?               @map("deleted_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @default(now()) @updatedAt @map("updated_at")
  cartItems       CartItem[]
  customerReviews CustomerReview[]
  wishlists       CustomerWishlist[]
  homepageItems   HomepageSectionItem[]
  inventory       Inventory[]
  orderItems      OrderItem[]
  attributeValues ProductAttributeValue[]
  downloads       ProductDownload[]
  faqs            ProductFaq[]
  features        ProductFeature[]
  images          ProductImage[]
  relatedTo       ProductRelated[]        @relation("RelatedToProduct")
  relatedProducts ProductRelated[]        @relation("ProductToRelated")
  reviews         ProductReview[]
  seo             ProductSeo?
  shipping        ProductShipping?
  specifications  ProductSpecification[]
  tagMappings     ProductTagMapping[]
  variants        ProductVariant[]
  options         ProductOption[]
  warranty        ProductWarranty?
  category        Category?               @relation(fields: [categoryId], references: [id])
  brand           Brand?                  @relation(fields: [brandId], references: [id])

  @@index([name])
  @@index([slug])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String   @map("image_url")
  isPrimary Boolean  @default(false) @map("is_primary")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductSpecification {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  name      String
  value     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specifications")
}

model ProductDownload {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  title        String
  fileUrl      String   @map("file_url")
  downloadType String   @map("download_type")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_downloads")
}

model ProductFeature {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  icon        String?
  title       String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_features")
}

model ProductFaq {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_faqs")
}

model ProductWarranty {
  id                  String   @id @default(uuid())
  productId           String   @unique @map("product_id")
  warrantyPeriod      String?  @map("warranty_period")
  warrantyType        String?  @map("warranty_type")
  warrantyDescription String?  @map("warranty_description")
  createdAt           DateTime @default(now()) @map("created_at")
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_warranty")
}

model ProductShipping {
  id              String   @id @default(uuid())
  productId       String   @unique @map("product_id")
  deliveryTime    String?  @map("delivery_time")
  shippingCharges Float?   @map("shipping_charges")
  shippingRegions String?  @map("shipping_regions")
  createdAt       DateTime @default(now()) @map("created_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_shipping")
}

model ProductRelated {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  relatedToId    String   @map("related_to_id")
  relationType   String   @map("relation_type")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  relatedProduct Product  @relation("RelatedToProduct", fields: [relatedToId], references: [id], onDelete: Cascade)
  product        Product  @relation("ProductToRelated", fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedToId])
  @@map("product_related_products")
}

model ProductSeo {
  id             String   @id @default(uuid())
  productId      String   @unique @map("product_id")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  seoKeywords    String?  @map("seo_keywords")
  canonicalUrl   String?  @map("canonical_url")
  openGraphImage String?  @map("open_graph_image")
  createdAt      DateTime @default(now()) @map("created_at")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_seo")
}

model ProductAttribute {
  id        String                  @id @default(uuid())
  name      String                  @unique
  createdAt DateTime                @default(now()) @map("created_at")
  values    ProductAttributeValue[]

  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String           @id @default(uuid())
  attributeId String           @map("attribute_id")
  productId   String           @map("product_id")
  value       String
  createdAt   DateTime         @default(now()) @map("created_at")
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@map("product_attribute_values")
}

model ProductVariant {
  id          String      @id @default(uuid())
  productId   String      @map("product_id")
  sku         String      @unique
  price       Float
  salePrice   Float?      @map("sale_price")
  stock       Int         @default(0)
  weight      Float?
  isDefault   Boolean     @default(false) @map("is_default")
  isActive    Boolean     @default(true) @map("is_active")
  variantSlug String?     @map("variant_slug")
  name        String
  deletedAt   DateTime?   @map("deleted_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")
  cartItems   CartItem[]
  inventory   Inventory[]
  orderItems  OrderItem[]
  options     ProductVariantOption[]
  images      ProductVariantImage[]
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model ProductOption {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  name        String
  displayType String   @default("select") @map("display_type")
  sortOrder   Int      @default(0) @map("sort_order")
  
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  values      ProductOptionValue[]

  @@map("product_options")
}

model ProductOptionValue {
  id            String   @id @default(uuid())
  optionId      String   @map("option_id")
  value         String
  displayValue  String?  @map("display_value")
  colorCode     String?  @map("color_code")
  imageUrl      String?  @map("image_url")
  sortOrder     Int      @default(0) @map("sort_order")

  option        ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants      ProductVariantOption[]

  @@map("product_option_values")
}

model ProductVariantOption {
  variantId     String  @map("variant_id")
  optionValueId String  @map("option_value_id")

  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@map("product_variant_options")
}

model ProductVariantImage {
  id         String   @id @default(uuid())
  variantId  String   @map("variant_id")
  imageUrl   String   @map("image_url")
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")

  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("product_variant_images")
}

model ProductTag {
  id       String              @id @default(uuid())
  name     String              @unique
  slug     String              @unique
  mappings ProductTagMapping[]

  @@map("product_tags")
}

model ProductTagMapping {
  productId String     @map("product_id")
  tagId     String     @map("tag_id")
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tag_mapping")
}

model ProductReview {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  userId     String?  @map("user_id")
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  user       User?    @relation(fields: [userId], references: [id])
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

model Warehouse {
  id        String      @id @default(uuid())
  name      String
  location  String?
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  inventory Inventory[]

  @@map("warehouses")
}

model Inventory {
  id           String                 @id @default(uuid())
  productId    String                 @map("product_id")
  variantId    String?                @map("variant_id")
  warehouseId  String                 @map("warehouse_id")
  quantity     Int                    @default(0)
  reservedQty  Int                    @default(0) @map("reserved_quantity")
  updatedAt    DateTime               @default(now()) @updatedAt @map("updated_at")
  warehouse    Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant      ProductVariant?        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  transactions InventoryTransaction[]

  @@map("inventory")
}

model InventoryTransaction {
  id              String    @id @default(uuid())
  inventoryId     String    @map("inventory_id")
  transactionType String    @map("transaction_type")
  quantity        Float
  referenceId     String?   @map("reference_id")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

model Customer {
  id            String                 @id @default(uuid())
  userId        String                 @map("user_id")
  phone         String?
  rewardPoints  Int                    @default(0) @map("reward_points")
  customerType  String                 @default("retail") @map("customer_type")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @default(now()) @updatedAt @map("updated_at")
  carts         Cart[]
  couponUsages  CouponUsage[]
  addresses     CustomerAddress[]
  notifications CustomerNotification[]
  reviews       CustomerReview[]
  sessions      CustomerSession[]
  wishlist      CustomerWishlist[]
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@map("customers")
}

model CustomerAddress {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  name           String?
  phone          String?
  addressLine1   String   @map("address_line_1")
  addressLine2   String?  @map("address_line_2")
  city           String
  state          String
  postalCode     String   @map("postal_code")
  country        String
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billingOrders  Order[]  @relation("BillingAddress")
  shippingOrders Order[]  @relation("ShippingAddress")

  @@map("customer_addresses")
}

model CustomerNotification {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  title      String
  message    String
  type       String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_notifications")
}

model CustomerSession {
  id           String   @id @default(uuid())
  customerId   String   @map("customer_id")
  token        String   @unique
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  isActive     Boolean  @default(true) @map("is_active")
  lastActivity DateTime @default(now()) @map("last_activity")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_sessions")
}

model CustomerWishlist {
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([customerId, productId])
  @@map("customer_wishlist")
}

model CustomerReview {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  rating     Int
  reviewText String?  @map("review_text")
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_reviews")
}

model Order {
  id                String               @id @default(uuid())
  customerId        String?              @map("customer_id")
  orderNumber       String               @unique @map("order_number")
  status            String               @default("PENDING")
  totalAmount       Float                @map("total_amount")
  taxAmount         Float                @default(0) @map("tax_amount")
  shippingAmount    Float                @default(0) @map("shipping_amount")
  discountAmount    Float                @default(0) @map("discount_amount")
  shippingAddressId String?              @map("shipping_address_id")
  billingAddressId  String?              @map("billing_address_id")
  notes             String?
  deletedAt         DateTime?            @map("deleted_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at")
  couponUsages      CouponUsage[]
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  billingAddress    CustomerAddress?     @relation("BillingAddress", fields: [billingAddressId], references: [id])
  shippingAddress   CustomerAddress?     @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  customer          Customer?            @relation(fields: [customerId], references: [id])
  payments          Payment[]
  shipments         Shipment[]

  @@map("orders")
}

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String          @map("order_id")
  productId  String?         @map("product_id")
  variantId  String?         @map("variant_id")
  quantity   Int
  unitPrice  Float           @map("unit_price")
  totalPrice Float           @map("total_price")
  createdAt  DateTime        @default(now()) @map("created_at")
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  product    Product?        @relation(fields: [productId], references: [id])
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  status    String
  comments  String?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [createdBy], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model Payment {
  id               String    @id @default(uuid())
  orderId          String    @map("order_id")
  paymentMethod    String    @map("payment_method")
  transactionId    String?   @map("transaction_id")
  gatewayOrderId   String?   @map("gateway_order_id")
  gatewayPaymentId String?   @map("gateway_payment_id")
  gatewayResponse  String?   @map("gateway_response")
  amount           Float
  status           String
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SearchLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  searchTerm  String   @map("search_term")
  resultCount Int      @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("search_logs")
}

model SearchSettings {
  id                     String   @id @default("default")
  enableSuggestions      Boolean  @default(true) @map("enable_suggestions")
  enableRecent           Boolean  @default(true) @map("enable_recent")
  enableAnalytics        Boolean  @default(true) @map("enable_analytics")
  resultsPerPage         Int      @default(20) @map("results_per_page")

  @@map("search_settings")
}

model PaymentGateway {
  id             String   @id @default(uuid())
  name           String
  gatewayCode    String   @unique @map("gateway_code")
  isEnabled      Boolean  @default(false) @map("is_enabled")
  isTestMode     Boolean  @default(true) @map("is_test_mode")
  keyId          String?  @map("key_id")
  keySecret      String?  @map("key_secret")
  webhookSecret  String?  @map("webhook_secret")
  displayName    String?  @map("display_name")
  description    String?
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("payment_gateways")
}

model Shipment {
  id                String    @id @default(uuid())
  orderId           String    @map("order_id")
  carrier           String?
  trackingNumber    String?   @map("tracking_number")
  trackingUrl       String?   @map("tracking_url")
  status            String
  estimatedDelivery DateTime? @map("estimated_delivery")
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

model Cart {
  id         String     @id @default(uuid())
  customerId String?    @map("customer_id")
  sessionId  String?    @map("session_id")
  status     String     @default("ACTIVE")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")
  items      CartItem[]
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String          @map("cart_id")
  productId String          @map("product_id")
  variantId String?         @map("variant_id")
  quantity  Int
  addedAt   DateTime        @default(now()) @map("added_at")
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  discountType   String        @map("discount_type")
  discountValue  Float         @map("discount_value")
  minOrderAmount Float?        @map("min_order_amount")
  maxDiscountAmt Float?        @map("max_discount_amount")
  startDate      DateTime?     @map("start_date")
  endDate        DateTime?     @map("end_date")
  usageLimit     Int?          @map("usage_limit")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  usages         CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id              String   @id @default(uuid())
  couponId        String   @map("coupon_id")
  orderId         String   @map("order_id")
  customerId      String   @map("customer_id")
  discountApplied Float    @map("discount_applied")
  usedAt          DateTime @default(now()) @map("used_at")
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@map("coupon_usage")
}

model Banner {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String   @map("image_url")
  linkUrl   String?  @map("link_url")
  position  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

model HomepageSection {
  id        String                @id @default(uuid())
  name      String
  type      String
  sortOrder Int                   @default(0) @map("sort_order")
  isActive  Boolean               @default(true) @map("is_active")
  createdAt DateTime              @default(now()) @map("created_at")
  items     HomepageSectionItem[]

  @@map("homepage_sections")
}

model HomepageSectionItem {
  id         String          @id @default(uuid())
  sectionId  String          @map("section_id")
  productId  String?         @map("product_id")
  categoryId String?         @map("category_id")
  imageUrl   String?         @map("image_url")
  title      String?
  subTitle   String?         @map("sub_title")
  linkUrl    String?         @map("link_url")
  sortOrder  Int             @default(0) @map("sort_order")
  createdAt  DateTime        @default(now()) @map("created_at")
  category   Category?       @relation(fields: [categoryId], references: [id])
  product    Product?        @relation(fields: [productId], references: [id])
  section    HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("homepage_section_items")
}

model Menu {
  id        String     @id @default(uuid())
  name      String
  location  String
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  items     MenuItem[]

  @@map("menus")
}

model MenuItem {
  id        String     @id @default(uuid())
  menuId    String     @map("menu_id")
  parentId  String?    @map("parent_id")
  title     String
  url       String?
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  parent    MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuHierarchy")
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model ThemeSetting {
  id        String   @id @default(uuid())
  keyName   String   @unique @map("key_name")
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("theme_settings")
}

model Page {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  content     String?
  isPublished Boolean       @default(false) @map("is_published")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")
  sections    PageSection[]

  @@map("pages")
}

model PageSection {
  id          String  @id @default(uuid())
  pageId      String  @map("page_id")
  sectionType String  @map("section_type")
  content     String?
  sortOrder   Int     @default(0) @map("sort_order")
  page        Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("page_sections")
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  blogs     Blog[]

  @@map("blog_categories")
}

model Blog {
  id          String        @id @default(uuid())
  categoryId  String?       @map("category_id")
  authorId    String?       @map("author_id")
  title       String
  slug        String        @unique
  content     String
  imageUrl    String?       @map("image_url")
  isPublished Boolean       @default(false) @map("is_published")
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")
  author      User?         @relation(fields: [authorId], references: [id])
  category    BlogCategory? @relation(fields: [categoryId], references: [id])

  @@map("blogs")
}

model NotificationTemplate {
  id            String         @id @default(uuid())
  name          String         @unique
  channel       String
  subject       String?
  body          String
  createdAt     DateTime       @default(now()) @map("created_at")
  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id           String                @id @default(uuid())
  userId       String?               @map("user_id")
  templateId   String?               @map("template_id")
  status       String                @default("PENDING")
  errorMessage String?               @map("error_message")
  sentAt       DateTime?             @map("sent_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  template     NotificationTemplate? @relation(fields: [templateId], references: [id])
  user         User?                 @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model ContactRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_requests")
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  isActive     Boolean  @default(true) @map("is_active")
  subscribedAt DateTime @default(now()) @map("subscribed_at")

  @@map("newsletter_subscribers")
}
