# GEMINI_API_KEY: Required for Gemini AI API calls.

GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.

APP_URL="MY_APP_URL"

# WHATSAPP_API_URL: Your SMS/WhatsApp provider Gateway Endpoint
WHATSAPP_API_URL=
# WHATSAPP_API_KEY: Authentication key to authorize outbound WhatsApp dispatches
WHATSAPP_API_KEY=
